{
  "name": "@ashish-um/nook-files",
  "version": "1.0.0",
  "description": "Binary file storage in Google Drive — companion to @ashish-um/nook",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "keywords": [
    "google-drive",
    "storage",
    "binary",
    "files",
    "upload",
    "appdata"
  ],
  "author": "ashish-um",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ashish-um/nook-files"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "xhr2": "^0.2.1"
  }
}
