{
  "name": "@ashish-um/nook",
  "version": "1.0.3",
  "description": "A reusable TypeScript module for using Google Drive as per-user cloud storage",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "nook-documentation.md",
    "nook-react-nextjs-guide.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "keywords": [
    "google-drive",
    "crud",
    "storage",
    "appdata",
    "drive-api"
  ],
  "author": "ashish-um",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashish-um/nook"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
